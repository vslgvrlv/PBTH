{
  "name": "paintball-hub",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server/index.js",
    "server": "nodemon server/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "npm run typecheck",
    "test": "vitest run",
    "test:unit": "vitest run __tests__/unit",
    "test:e2e": "playwright test --config=playwright.config.ts",
    "gen:api-types": "openapi-typescript http://127.0.0.1:8000/api/v1/openapi.json -o generated/openapi.d.ts"
  },
  "dependencies": {
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "date-fns": "^2.30.0",
    "express": "^4.18.2",
    "lucide-react": "^0.263.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.30.3",
    "sqlite3": "^5.1.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.0",
    "@testing-library/react": "^16.2.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.0.3",
    "nodemon": "^3.0.1",
    "openapi-typescript": "^7.5.2",
    "typescript": "^5.7.2",
    "vite": "^4.4.5",
    "vitest": "^2.1.8"
  }
}
